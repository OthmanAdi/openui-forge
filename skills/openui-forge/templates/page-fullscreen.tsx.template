"use client";

import "@openuidev/react-ui/components.css";

import { FullScreen } from "@openuidev/react-ui";
import {
  openAIAdapter,
  openAIReadableStreamAdapter,
  openAIMessageFormat,
} from "@openuidev/react-headless";
import { ${LIBRARY_NAME} } from "${LIBRARY_IMPORT_PATH}";

// FullScreen renders a full-viewport chat interface with built-in message
// history, input field, and streaming display. processMessage connects it
// to your backend; streamProtocol + messageFormat tell it how to parse the
// streaming response.
//
// Pick streamProtocol to match your backend's output format:
//   - SSE (lines prefixed with `data: ...\n\n`)    -> openAIAdapter()
//   - NDJSON (one raw JSON object per line)         -> openAIReadableStreamAdapter()

export default function ${PAGE_NAME}() {
  return (
    <FullScreen
      agentName="${APP_TITLE}"
      componentLibrary={${LIBRARY_NAME}}
      // processMessage is called each time the user sends a message.
      // It must return a Response whose body is the streaming chat output.
      processMessage={async ({ messages, abortController }) => {
        return fetch("/api/chat", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            messages: openAIMessageFormat.toApi(messages),
          }),
          signal: abortController.signal,
        });
      }}
      // streamProtocol must be CALLED as a function. The default below is SSE.
      // If your backend emits NDJSON (e.g. via OpenAI's `response.toReadableStream()`),
      // switch to: streamProtocol={openAIReadableStreamAdapter()}
      streamProtocol={openAIAdapter()}
      // messageFormat controls how conversation history is serialized
      // before being sent to processMessage. openAIMessageFormat produces
      // the { role, content } shape that OpenAI (and compatible) APIs expect.
      messageFormat={openAIMessageFormat}
    />
  );
}
