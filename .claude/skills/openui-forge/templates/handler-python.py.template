# ---------------------------------------------------------------------------
# Setup
# ---------------------------------------------------------------------------

SYSTEM_PROMPT_PATH = Path(__file__).parent / "src" / "generated" / "system-prompt.txt"
system_prompt = SYSTEM_PROMPT_PATH.read_text(encoding="utf-8")

client = AsyncOpenAI()

app = FastAPI(title="${PROJECT_NAME} API")

# CORS — allow the Next.js dev server and any local frontend
app.add_middleware(
    CORSMiddleware,
    allow_origins=["${FRONTEND_ORIGIN}"],
    allow_credentials=True,
    allow_methods=["*"],
    allow_headers=["*"],
)


# ---------------------------------------------------------------------------
# OpenAI NDJSON chunk helper
# ---------------------------------------------------------------------------

def openai_chunk(completion_id: str, content: str, finish_reason: str | None) -> str:
    """Build one line of OpenAI-compatible NDJSON."""
    return json.dumps({
        "id": completion_id,
        "object": "chat.completion.chunk",
        "choices": [
            {
                "index": 0,
                "delta": {"content": content} if content else {},
                "finish_reason": finish_reason,
            }
        ],
    }) + "\n"


# ---------------------------------------------------------------------------
# Streaming generators
# ---------------------------------------------------------------------------

async def stream_openai(messages: list[dict]) -> AsyncGenerator[str, None]:
    """Stream from OpenAI and yield NDJSON chunks."""
    completion_id = f"chatcmpl-{int(time.time() * 1000)}"

    stream = await client.chat.completions.create(
        model="${MODEL}",
        stream=True,
        messages=[
            {"role": "system", "content": system_prompt},
            *messages,
        ],
    )

    async for chunk in stream:
        delta = chunk.choices[0].delta if chunk.choices else None
        if delta and delta.content:
            yield openai_chunk(completion_id, delta.content, None)

    yield openai_chunk(completion_id, "", "stop")


